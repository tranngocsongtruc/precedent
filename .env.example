# ── Anthropic (reasoning model for every agent) ──────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
# Default model for agents. Opus for the hard reasoning, Haiku for cheap steps.
ANTHROPIC_MODEL="claude-opus-4-8"

# ── Redis Cloud (precedent graph + vector search) ────────────────────────────
# From redis.io/try-free -> Databases -> Connect -> redis-py.
# Either provide a single URL...
REDIS_URL="redis://default:<password>@<host>:<port>"
# ...or the split values (URL takes precedence if set):
REDIS_HOST=""
REDIS_PORT=""
REDIS_USERNAME="default"
REDIS_PASSWORD=""

# ── LangCache (semantic cache for repeated precedent lookups) — optional ─────
# Redis Cloud -> LangCache -> Quick create. Leave blank to disable caching.
LANGCACHE_HOST=""
LANGCACHE_CACHE_ID=""
LANGCACHE_API_KEY=""

# ── Agent Memory Server (cross-session approver / reasoning memory) — optional
# Redis Cloud -> Agent Memory -> Quick create. Leave blank to disable.
AGENT_MEMORY_URL=""
AGENT_MEMORY_STORE_ID=""
AGENT_MEMORY_API_KEY=""

# ── Embeddings ───────────────────────────────────────────────────────────────
# Default backend runs locally via @huggingface/transformers (no key needed).
# Set to "voyage" + a key to use Voyage AI instead.
EMBEDDINGS_BACKEND="local"
VOYAGE_API_KEY=""

# ── Deepgram (voice intake) ──────────────────────────────────────────────────
# Permanent key stays server-side; the browser gets a short-lived granted JWT.
DEEPGRAM_API_KEY=""

# ── Browserbase + Stagehand (real cross-system pulls) — optional ─────────────
# browserbase.com/settings. Without these, connectors fall back to mock data.
BROWSERBASE_API_KEY=""
BROWSERBASE_PROJECT_ID=""

# ── Band.ai (multi-agent coordination + audit trail) — optional, REST ────────
# Base + per-agent API key. Without these, audit writes are skipped.
BAND_REST_URL="https://app.band.ai"
BAND_API_KEY=""
BAND_AGENT_ID=""

# ── Arize AX (OpenTelemetry tracing for every agent) — optional ──────────────
# app.arize.com -> Settings -> Space & API Keys. Without these, tracing is a no-op.
ARIZE_SPACE_ID=""
ARIZE_API_KEY=""
ARIZE_PROJECT_NAME="precedent"
ARIZE_OTLP_ENDPOINT="https://otlp.arize.com/v1/traces"

# ── AgentSpan durable-workflow sidecar (Python) — optional ───────────────────
# The TS app calls this for the durable approval-wait step. See sidecar/README.md.
AGENTSPAN_SIDECAR_URL="http://localhost:8088"

# ── Sentry (error monitoring) — optional ─────────────────────────────────────
# sentry.io -> Project -> Settings -> Client Keys (DSN). Without a DSN, Sentry is
# inert. Use the SAME DSN for both (server + browser).
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
# Only needed to upload source maps at build time (nicer stack traces):
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

